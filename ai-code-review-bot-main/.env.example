# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Supabase (free PostgreSQL) - https://supabase.com
DB_URL=jdbc:postgresql://db.YOUR_SUPABASE_ID.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=your_supabase_password

# Claude API (free tier) - https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your-key-here

# GitHub Personal Access Token - https://github.com/settings/tokens
# Permissions needed: pull_requests (read/write), issues (write)
GITHUB_TOKEN=github_pat_your_token_here

# Any random string - must match what you set in GitHub webhook settings
GITHUB_WEBHOOK_SECRET=any-random-string-you-choose

# For React frontend (optional - defaults to localhost:8080)
REACT_APP_API_URL=http://localhost:8080/api
